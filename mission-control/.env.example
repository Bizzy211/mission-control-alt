# Mission Control Environment Variables
# Copy this file to .env.local and fill in values as needed.

# ─── API Authentication ─────────────────────────────────────────────────────
# Set a secret token to protect API endpoints from unauthorized access.
# When not set, all API requests pass through (suitable for localhost-only use).
#
# Generate a token with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Both variables must match. MC_API_TOKEN is used server-side (middleware),
# NEXT_PUBLIC_MC_API_TOKEN is used client-side (browser fetch calls).
#
# MC_API_TOKEN=your-secret-token-here
# NEXT_PUBLIC_MC_API_TOKEN=your-secret-token-here

# ─── Skill Store (SkillsMP) ──────────────────────────────────────────────────
# API key for searching the SkillsMP marketplace (350K+ agent skills).
# Get a free key at: https://skillsmp.com/docs/api
#
# SKILLSMP_API_KEY=sk_live_...

# ─── Future ─────────────────────────────────────────────────────────────────
# GITHUB_TOKEN=
# DATABASE_URL=
